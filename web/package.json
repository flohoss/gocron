{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --strictPort",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "types": "openapi-ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@vueuse/core": "^14.3.0",
    "daisyui": "^5.5.23",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.35",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.98.1",
    "@iconify-json/fa-solid": "^1.2.2",
    "@iconify-json/fa7-solid": "^1.2.4",
    "@iconify-json/simple-icons": "^1.2.85",
    "@types/humanize-duration": "^3.27.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.4"
  },
  "prettier": {
    "printWidth": 160,
    "singleQuote": true,
    "semi": true,
